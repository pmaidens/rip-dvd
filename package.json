{
  "name": "rip-dvd",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.23.1 <23"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm check:toolchain && pnpm typecheck && pnpm test",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "db:check": "pnpm --filter @rip-dvd/data-access db:check",
    "dev": "pnpm --filter @rip-dvd/web dev",
    "test": "pnpm --filter @rip-dvd/config --filter @rip-dvd/data-access --filter @rip-dvd/worker-runtime --filter @rip-dvd/web test",
    "test:compose-workers": "sh scripts/smoke-compose-workers.sh",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
