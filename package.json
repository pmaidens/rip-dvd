{
  "name": "rip-dvd",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm typecheck && pnpm test",
    "dev": "pnpm --filter @rip-dvd/web dev",
    "test": "pnpm --filter @rip-dvd/config test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
