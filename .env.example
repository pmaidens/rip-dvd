# Compose uses writable named volumes by default. Uncomment these optional
# overrides to bind-mount host libraries after preparing their ownership as
# documented in README.md.
# RIP_DVD_MEDIA_LIBRARY_HOST_PATH=./.local/media
# RIP_DVD_ORIGINALS_LIBRARY_HOST_PATH=./.local/originals
RIP_DVD_WEB_PORT=3000

# Worker defaults. Device passthrough will be enabled with the archive workflow.
RIP_DVD_ARCHIVE_DEVICE_PATH=/dev/sr0
RIP_DVD_WORKER_POLL_INTERVAL_MS=5000
RIP_DVD_ARCHIVE_WORKER_CONCURRENCY=1
RIP_DVD_ENCODE_WORKER_CONCURRENCY=1
